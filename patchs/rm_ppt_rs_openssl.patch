+        bmp[18..22].copy_from_slice(&100u32.to_le_bytes()); // width=100
+        bmp[22..26].copy_from_slice(&200u32.to_le_bytes()); // height=200
+        let (w, h, fmt) = read_image_dimensions(&bmp).unwrap();
