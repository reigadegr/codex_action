+<p:extLst>
+<p:ext uri="{{DAA4B4D4-6D71-4841-9C94-3DE7FCFB9230}}">
+<p14:media xmlns:p14="http://schemas.microsoft.com/office/powerpoint/2010/main" r:embed="{}"/>
+</p:ext>
+</p:extLst>
+</p:nvPr>
+</p:nvPicPr>
+<p:blipFill>
+<a:blip r:embed="{}"/>
+<a:stretch>
+<a:fillRect/>
