+    #[test]
+    fn test_create_notes_master_rels_xml() {
+        let xml = create_notes_master_rels_xml();
+        assert!(xml.contains("theme1.xml"));
+    }
+}
diff --git a/codex-rs/vendor/ppt-rs/src/generator/package_xml.rs b/codex-rs/vendor/ppt-rs/src/generator/package_xml.rs
