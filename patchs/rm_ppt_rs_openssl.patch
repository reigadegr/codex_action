+
+    // =========================================================================
+    // SLIDE 8: Real-World Dashboard with Dimension API
+    // =========================================================================
+    println!("📊 Slide 8: Real-World Dashboard");
+
+    // 4 evenly-spaced KPI cards using percent
+    let kpi_colors = ["1565C0", "2E7D32", "EF6C00", "7B1FA2"];
