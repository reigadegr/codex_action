+            .add_bullet("Video formats: MP4, WMV, AVI, MOV, MKV, WebM")
+            .add_bullet("Audio formats: MP3, WAV, WMA, M4A, OGG, FLAC")
+            .add_bullet("Playback options: auto-play, loop, mute")
