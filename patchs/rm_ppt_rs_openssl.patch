+        let path = self.output_dir.join("01_basic.pptx");
+        let mut file = File::create(&path)
+            .map_err(|e| format!("Cannot create file: {}", e))?;
+        file.write_all(&data)
+            .map_err(|e| format!("Cannot write file: {}", e))?;
+        file.flush()
+            .map_err(|e| format!("Cannot flush file: {}", e))?;
